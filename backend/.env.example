# IDC 机房管理平台后端环境变量样例
# 复制为 .env 并按需修改

# 数据库连接串。
# 开发/测试（SQLite，沙箱直接跑通）：
DATABASE_URL=sqlite+aiosqlite:///./idc.db
# 生产（PostgreSQL，零改代码切换）：
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/idc

# 缓存：默认 false 使用进程内字典（带 TTL），true 时使用 Redis
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# 统一 API 前缀
API_PREFIX=/api/v1

# 大屏缓存 TTL（秒）
CACHE_TTL=30
