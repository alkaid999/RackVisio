# ============================================================
# RackVisio Docker 部署环境变量模板
#
# 用法：复制为 .env 并按需修改（.env 已被 gitignore，不会入库）
#       cp .env.example .env
#
# 说明：docker-compose.yml 中的 ${VAR:-默认值} 会优先读取本文件；
#       未提供时使用默认值（仅适合本地/演示，生产请改强密码与密钥）。
#
# 📌 定位：Docker 部署使用 PostgreSQL；SQLite 仅用于本地零配置开发。
# ============================================================

# ===== 数据库（PostgreSQL，Docker 部署用）=====
# 数据库名 / 用户名 / 密码；三者需保持一致，backend 的 DATABASE_URL 由它们自动拼出
POSTGRES_DB=rackvisio
POSTGRES_USER=rackvisio
POSTGRES_PASSWORD=rackvisio_pass

# ===== 后端 =====
# JWT 签名密钥：生产务必改为强随机值（生成示例：openssl rand -hex 32）
SECRET_KEY=change-me-in-prod-rackvisio-secret-key
# 令牌有效期（小时）
TOKEN_EXPIRE_HOURS=12
# 首次启动 seed 的默认管理员密码（用户名固定为 admin）
INITIAL_ADMIN_PASSWORD=admin123
# 机房统计 / 看板缓存 TTL（秒）
CACHE_TTL=30
# 是否启用 Redis 缓存（默认关闭，使用进程内字典缓存）
#   当前为轻量单实例部署，无需 Redis；多实例前需先修复 RedisCache 序列化（详见 DEPLOY.md）
REDIS_ENABLED=false
# Redis 连接串（仅当 REDIS_ENABLED=true 时生效；启用 docker-compose.yml 中 redis 服务后用此值）
# REDIS_URL=redis://redis:6379/0

# ===== 前端 / 访问 =====
# 宿主机映射端口（前端 nginx 容器内监听 80）
HTTP_PORT=8080
